.about-me {
    padding: 60px 20px;
    background-color: #f9f9f9;
    text-align: center;
    font-family: 'MV Boli', sans-serif; /* ދިވެހި ފޮންޓް */
}

.about-me h2 {
    color: #2c3e50;
    margin-bottom: 20px;
    font-size: 2rem;
}

.about-me p {
    color: #555;
    font-size: 1.2rem;
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto;
}
